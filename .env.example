# Ollama Configuration
OLLAMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://ollama.llm-serving.svc.cluster.local:11434

# Agent Configuration
AGENT_LOG_LEVEL=info
AGENT_PORT=8000
AGENT_WORKERS=2

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4317
OTEL_SERVICE_NAME=ai-agent

# Kind
KIND_CLUSTER_NAME=ai-agent-cluster
KIND_NODE_COUNT=3
